# Generated by Cargo
# will have compiled files and executables
debug/
target/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Added by cargo

/target
/.idea

/docs/book

# mdbook-mermaid runtime assets — generated by `mdbook-mermaid install docs`
# (run automatically by the `docs-*` just recipes and in CI before the build).
/docs/mermaid.min.js
/docs/mermaid-init.js

# Claude files
.claude/tmp/
.claude/settings.local.json
.claude/worktrees/

# Node.js dependencies
node_modules/

# Playwright snapshot baselines are NOT committed (DEV-6642). They are a one-time
# pre-/post-migration A/B reference, captured in a single environment at verification
# time, not a permanent CI visual-regression gate. The committed artifact is the spec
# code; the *-snapshots/ baseline dirs and run artifacts are ignored by per-suite
# .gitignore files under the *-e2e-tests directories.

.DS_Store

# Generated unified DPE stylesheet (built by `just css` / `just css-release`, DEV-6642)
modules/dpe/public/assets/app.css
modules/dpe/public/assets/app.*.css


# Nix
result
result-*
.direnv/

# IDE related
/.vscode

# In-memory repository caches
modules/dpe/server/data/records/*-records.json
