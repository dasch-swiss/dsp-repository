<?xml version="1.0" encoding="UTF-8"?>
<!-- Main schema for validating OAI-PMH responses.
     Imports OAI-PMH 2.0, OAI Dublin Core, and OAI DataCite schemas from local copies. -->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:oai="http://www.openarchives.org/OAI/2.0/"
           xmlns:oai_dc="http://www.openarchives.org/OAI/2.0/oai_dc/"
           xmlns:dc="http://purl.org/dc/elements/1.1/"
           xmlns:oai_datacite="http://schema.datacite.org/oai/oai-1.1/"
           xmlns:datacite="http://datacite.org/schema/kernel-4">

  <xs:import namespace="http://www.openarchives.org/OAI/2.0/"
             schemaLocation="OAI-PMH.xsd"/>

  <xs:import namespace="http://www.openarchives.org/OAI/2.0/oai_dc/"
             schemaLocation="oai_dc.xsd"/>

  <xs:import namespace="http://purl.org/dc/elements/1.1/"
             schemaLocation="simpledc20021212.xsd"/>

  <xs:import namespace="http://schema.datacite.org/oai/oai-1.1/"
             schemaLocation="oai_datacite.xsd"/>

  <xs:import namespace="http://datacite.org/schema/kernel-4"
             schemaLocation="datacite-kernel-4.xsd"/>

</xs:schema>
